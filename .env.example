# Generic env template. For environment-specific defaults, see:
#   .env.dev.example   (local development with the DiVA Dev Discord app)
#   .env.prod.example  (Railway / production)

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Comma-separated list of guild IDs to register slash commands in
DISCORD_GUILD_IDS=

# Anthropic
ANTHROPIC_API_KEY=

# Bot environment: 'production' (Railway) or 'development' (local). Defaults to development.
# Update notices only post when BOT_ENV=production.
BOT_ENV=development

# Owner Discord user ID — gates owner-only commands like /credits add
OWNER_USER_ID=

# Data directory (set to Railway volume path in production, leave blank for local)
# DATA_DIR=/app/data

# Monitoring
ERROR_CHANNEL_ID=
METRICS_CHANNEL_ID=
NOTIFY_USER_ID=

# Budget
MONTHLY_TOKEN_BUDGET_USD=20

# Bot Tuning
MAX_HISTORY_MESSAGES=6
MAX_RESPONSE_TOKENS=512
PERSONALITY_DIGEST_INTERVAL=15

# Rate Limiting
RATE_LIMIT_USER_SECONDS=5
RATE_LIMIT_CHANNEL_COUNT=5
RATE_LIMIT_CHANNEL_SECONDS=10

# Maintenance
HISTORY_RETENTION_DAYS=14

# Logging
LOG_LEVEL=info
