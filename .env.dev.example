# Local development environment template.
# Copy this to .env for local runs (do NOT commit your filled-in .env).

# Required: dev Discord application credentials
# (Create a SECOND Discord application named "DiVA Dev" in the Developer Portal,
#  invite it to a private test server, and paste the dev token + client ID here.)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Comma-separated list of guild IDs where slash commands will be registered.
# Use only your private test server here — never list a prod guild.
DISCORD_GUILD_IDS=

# Required: your personal Anthropic API key (or a dedicated dev key)
ANTHROPIC_API_KEY=

# Marks this process as the dev bot. Disables update notices, uses a separate database,
# and surfaces a warning on startup. The single most important variable in this file.
BOT_ENV=development

# Owner Discord user ID (your account). Gates owner-only commands like /credits add.
OWNER_USER_ID=

# Optional: where to send error notifications and metrics on dev.
# Leaving blank disables them, which is fine for local development.
ERROR_CHANNEL_ID=
METRICS_CHANNEL_ID=
NOTIFY_USER_ID=

# Local data directory — leave blank to use the project root (./bot.dev.db will be created here).
# Do NOT set this to /app/data; that path is for Railway only.
# DATA_DIR=

# Bot tuning (defaults are fine for dev)
MAX_HISTORY_MESSAGES=6
MAX_RESPONSE_TOKENS=512
PERSONALITY_DIGEST_INTERVAL=15

# Rate limiting (defaults)
RATE_LIMIT_USER_SECONDS=5
RATE_LIMIT_CHANNEL_COUNT=5
RATE_LIMIT_CHANNEL_SECONDS=10

# Maintenance
HISTORY_RETENTION_DAYS=14

# Logging — debug recommended in dev for visibility
LOG_LEVEL=debug
