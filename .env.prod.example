# Production environment template (Railway).
# Set these as Railway environment variables — do NOT commit a filled-in copy.

# Required: prod Discord application credentials (the live DiVA application)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Comma-separated list of guild IDs where slash commands will be registered (your prod servers)
DISCORD_GUILD_IDS=

# Required: prod Anthropic API key
ANTHROPIC_API_KEY=

# Marks this process as the prod bot. Enables update notices.
# CRITICAL — must be exactly "production" (not "prod", not "PRODUCTION") on Railway.
BOT_ENV=production

# Owner Discord user ID (your account). Gates owner-only commands like /credits add.
OWNER_USER_ID=

# Production monitoring channels (your private servers, for owner alerts)
ERROR_CHANNEL_ID=
METRICS_CHANNEL_ID=
NOTIFY_USER_ID=

# Railway persistent volume mount point. MUST be set on Railway.
DATA_DIR=/app/data

# Bot tuning
MAX_HISTORY_MESSAGES=6
MAX_RESPONSE_TOKENS=512
PERSONALITY_DIGEST_INTERVAL=15

# Rate limiting
RATE_LIMIT_USER_SECONDS=5
RATE_LIMIT_CHANNEL_COUNT=5
RATE_LIMIT_CHANNEL_SECONDS=10

# Maintenance
HISTORY_RETENTION_DAYS=14

# Logging
LOG_LEVEL=info
